{
  "name": "viber-agent",
  "version": "0.1.0",
  "description": "A minimal Node.js coding agent framework",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./llm": {
      "types": "./dist/llm/index.d.ts",
      "import": "./dist/llm/index.js",
      "default": "./dist/llm/index.js"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "import": "./dist/tools/index.js",
      "default": "./dist/tools/index.js"
    }
  },
  "bin": {
    "viber": "dist/cli/cli.js",
    "viber-agent": "dist/cli/cli.js"
  },
  "files": [
    "dist",
    "prompts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --pretty --diagnostics --listEmittedFiles",
    "prepublishOnly": "npm run build",
    "start": "node dist/cli/cli.js",
    "dev": "tsx src/cli/cli.ts",
    "agent": "tsx src/cli/cli.ts",
    "boarding": "tsx src/cli/cli.ts --boarding",
    "test:cli": "node scripts/test-cli-pty.mjs",
    "logs:pretty": "node scripts/pretty-upstream.mjs"
  },
  "keywords": [
    "agent",
    "coding",
    "llm"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "conf": "^15.1.0",
    "diff": "^8.0.3",
    "ink": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^17.0.5",
    "openai": "^4.52.0",
    "parse-diff": "^0.11.1",
    "pino": "^10.3.1",
    "react": "^18.2.0",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "node-pty": "^1.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
