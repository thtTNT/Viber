# Viber Configuration
# Copy this file to .env and fill in your values
# Or run: viber --boarding

# Required: Your API key
OPENAI_API_KEY=sk-your-openai-api-key

# Optional: Custom API base URL (e.g. proxy, Azure, OpenRouter, SiliconFlow)
# The client appends /chat/completions itself, so use base URL only
# OPENAI_BASE_URL=https://api.openai.com/v1
# SiliconFlow: OPENAI_BASE_URL=https://api.siliconflow.cn/v1
# OPENAI_MODEL=Pro/deepseek-ai/DeepSeek-V3.2
# Alias (same as OPENAI_MODEL):
# BASE_MODEL=Pro/deepseek-ai/DeepSeek-V3.2

# Note: Agent requires an API that supports OpenAI-compatible tool_calls (function calling)
#
# Optional: MCP (Model Context Protocol) stdio servers — configure in workspace .viber/config.json
# (see /mcp in interactive mode). API keys stay in ~/.viber/config.json or OPENAI_API_KEY above.
